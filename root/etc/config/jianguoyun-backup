# 坚果云备份插件 - UCI配置文件
# 安装后自动生成，可通过LuCI界面修改

config global 'global'
	option webdav_url 'https://dav.jianguoyun.com/dav/'
	option username ''
	option password ''
	option remote_root 'OpenWrt_Backup'
	option max_remote_backups '10'
	option max_local_backups '5'
	option backup_storage 'tmp'
	option keep_local_backup '0'
	option config_version '1'

config light_backup 'light_backup'
	option enabled '0'
	option schedule 'daily'
	option time '03:00'
	option day '0'
	option day_month '1'

config full_backup 'full_backup'
	option enabled '0'
	option schedule 'weekly'
	option time '04:00'
	option day '0'
	option day_month '1'
